DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/scheduling?schema=public"

# Email (optional — if omitted, booking/cancel/reschedule APIs still work; emails are skipped)
# Option A: Custom SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# Option B: Gmail-style (uses smtp.gmail.com on port 465 by default if SMTP_HOST is unset)
EMAIL_USER=
EMAIL_PASS=
# Optional overrides when using EMAIL_USER / EMAIL_PASS without SMTP_HOST:
# EMAIL_SMTP_HOST=smtp.gmail.com
# EMAIL_PORT=465

EMAIL_FROM=

# Optional: used in emails if you add links later
NEXT_PUBLIC_APP_URL=http://localhost:3000
